      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "if (jsonData.token) {\r",
              "    pm.environment.set(\"admin_token\", jsonData.token);\r",
              "}"
