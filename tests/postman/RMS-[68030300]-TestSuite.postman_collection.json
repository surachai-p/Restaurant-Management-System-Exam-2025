        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Should return 400 Bad Request due to underpayment\", function () {\r",
              "    pm.response.to.have.status(400);\r",
              "});\r",
              "\r",
              "pm.test(\"Error message should be clear\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.error).to.exist;\r",
              "});"
