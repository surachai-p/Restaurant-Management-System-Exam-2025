{
  "name": "rms-backend",
  "version": "1.0.0",
  "description": "Restaurant Management System — Backend API (TypeScript + Prisma)",
  "engines": {
    "node": ">=25.8.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:newman": "newman run tests/postman/RMS-TestSuite-v2.json -e tests/postman/env-local.json --reporters cli"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.0",
    "newman": "^6.1.3",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "handlebars": "^4.7.9",
    "lodash": "^4.17.21",
    "flatted": "^3.4.2",
    "node-forge": "^1.3.4",
    "underscore": "^1.13.8",
    "jose": "^4.15.5",
    "qs": "^6.14.1",
    "esbuild": "^0.25.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}