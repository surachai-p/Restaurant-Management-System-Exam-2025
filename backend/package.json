steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '22'

      - name: Install dependencies
        run: npm install

      - name: Prepare Database and Build
        run: |
          echo "DATABASE_URL=file:./dev.db" > .env
          npx prisma generate
          npx prisma db push
          npm run build

      - name: Start Backend
        run: npm start & 

      - name: Wait for Server
        run: npx wait-on http://localhost:3001 --timeout 120000

      - name: Run Newman API Tests
        run: |
          newman run ../tests/postman/RMS-68030298-TestSuite-v2.json \
          -e ../tests/postman/env-ci.json \
          --reporters cli