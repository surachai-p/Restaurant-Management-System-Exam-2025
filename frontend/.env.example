# ==========================================
# Frontend Environment Variables
# ==========================================
# Instructions: Copy this file, rename it to .env.local, and fill in the values.

# ------------------------------------------
# Local Development
# ------------------------------------------
# Note: Vite proxy handles requests starting with /api and forwards them to localhost:3001
VITE_API_URL=/api

# ------------------------------------------
# Production
# ------------------------------------------
# Note: Point directly to your deployed backend URL (e.g., Render, Railway, Heroku)
# VITE_API_URL=https://rms-api-YOURNAME.onrender.com/api
